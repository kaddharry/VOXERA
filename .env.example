# ==========================================
# VOXERA Configuration File
# 1. Copy this to .env.local
# 2. Fill in the actual credentials
# ==========================================

# 1. LLM Settings (Groq / OpenAI compatible)
GROQ_API_KEYS=your_groq_api_key_1,your_groq_api_key_2
ANTHROPIC_API_KEY=your_anthropic_api_key_if_using_claude

# 2. Deepgram (Voice STT / TTS)
DEEPGRAM_API_KEY=your_deepgram_api_key

# 3. Supabase (PostgreSQL + pgvector)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# 4. Email / Integrations
RESEND_API_KEY=your_resend_api_key
